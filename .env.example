APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://rag_user:rag_password@postgres:5432/rag_postgres
TEST_DATABASE_URL=postgresql+psycopg://rag_user:rag_password@localhost:5434/rag_postgres_test
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
PG_TEST_HOST_PORT=5434

SUPPORTED_PG_VERSIONS=16,17,18
OFFICIAL_DOCS_BASE_URL=https://www.postgresql.org/docs
OFFICIAL_CRAWL_MAX_PAGES=40
OFFICIAL_REQUEST_TIMEOUT=20

CHUNK_SIZE=1200
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=18
RERANK_TOP_K=8
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=8
EMBEDDING_MAX_SEQ_LENGTH=8192
HASH_EMBEDDING_SEED=postgres-rag

# --- Groq generation (single provider) ---
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Embeddings ---
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-m3

# --- Corpus & data ---
CORPUS_DIR=corpus
SUPPLEMENTARY_DIR=corpus/tutorial
RAW_DOCS_DIR=data/raw_docs
NORMALIZED_DOCS_DIR=data/normalized_docs

ADMIN_API_KEY=change_me

APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://rag_user:rag_password@postgres:5432/rag_postgres
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

SUPPORTED_PG_VERSIONS=16,17,18
OFFICIAL_DOCS_BASE_URL=https://www.postgresql.org/docs
OFFICIAL_CRAWL_MAX_PAGES=40
OFFICIAL_REQUEST_TIMEOUT=20

CHUNK_SIZE=1200
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=18
RERANK_TOP_K=8
EMBEDDING_DIMENSION=1024
HASH_EMBEDDING_SEED=postgres-rag

# --- Groq generation (single provider) ---
GROQ_API_KEY=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
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Ollama (used only for embeddings, if EMBEDDING_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# --- Embedding provider: ollama | openai | hashing ---
EMBEDDING_PROVIDER=ollama

# --- OpenAI (optional, only for embeddings if EMBEDDING_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
USE_OPENAI_EMBEDDINGS=false

# --- Corpus & data ---
CORPUS_DIR=corpus
SUPPLEMENTARY_DIR=data/supplementary
RAW_DOCS_DIR=data/raw_docs
NORMALIZED_DOCS_DIR=data/normalized_docs

ADMIN_API_KEY=change_me
